{
  "name": "sink",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nuxt dev --port 7465",
    "dev:docs": "pnpm --filter @sink/docs dev",
    "build:docs": "pnpm --filter @sink/docs build",
    "preview:docs": "pnpm --filter @sink/docs preview",
    "analyze": "nuxt analyze",
    "test": "vitest",
    "prebuild": "pnpm build:sphere",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 nuxt build",
    "postbuild": "test \"$CF_PAGES:$CF_PAGES_BRANCH\" != \"1:master\" || pnpm db:migrate:remote",
    "build:map": "node scripts/build-map.js",
    "build:sphere": "node scripts/build-sphere.js",
    "build:colo": "node scripts/build-colo.js",
    "build:testimonials": "node scripts/build-testimonials.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "locales:check": "node scripts/check-locales.js",
    "types:check": "nuxt typecheck",
    "wrangler": "wrangler",
    "gen:types": "wrangler types --env-file .env.example",
    "deploy:config": "node scripts/cloudflare-deploy-config.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply sink --local",
    "db:migrate:remote": "pnpm deploy:config && wrangler d1 migrations apply DB --remote --config wrangler.deploy.jsonc",
    "deploy": "pnpm deploy:pages",
    "deploy:pages": "pnpm db:migrate:remote && wrangler pages deploy dist",
    "deploy:worker": "pnpm db:migrate:remote && wrangler deploy .output/server/index.mjs --assets .output/public --config wrangler.deploy.jsonc",
    "preview": "wrangler dev .output/server/index.mjs --assets .output/public ",
    "postinstall": "pnpm build:map && nuxt prepare",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@internationalized/date": "^3.12.2",
    "@lucide/vue": "^1.24.0",
    "@number-flow/vue": "^0.5.1",
    "@nuxt/eslint": "^1.16.0",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/i18n": "^10.4.1",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/vue-form": "^1.33.1",
    "@tanstack/vue-table": "^8.21.3",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^26.1.1",
    "@unovis/ts": "^1.6.7",
    "@unovis/vue": "^1.6.7",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "destr": "^2.0.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-vue": "^8.6.0",
    "es-toolkit": "^1.49.0",
    "eslint": "^10.7.0",
    "eslint-plugin-better-tailwindcss": "^4.6.1",
    "eslint-plugin-format": "^2.0.1",
    "h3": "^1.15.11",
    "intl-parse-accept-language": "^1.0.0",
    "jose": "^6.2.3",
    "jsonc-parser": "^3.3.1",
    "kysely": "0.29.3",
    "lint-staged": "^17.0.8",
    "nanoid": "^5.1.16",
    "nitropack": "^2.13.4",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "qr-code-styling": "^1.9.2",
    "reka-ui": "^2.10.1",
    "shadcn-nuxt": "^2.7.4",
    "shadcn-vue": "^2.7.4",
    "simple-git-hooks": "^2.13.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "topojson-client": "^3.1.0",
    "tw-animate-css": "^1.4.0",
    "twgl.js": "^7.0.0",
    "typescript": "^5.9.3",
    "ua-parser-js": "^2.0.10",
    "ufo": "^1.6.4",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "virtua": "^0.49.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-input-otp": "^0.3.2",
    "vue-sonner": "^2.0.9",
    "vue-tsc": "^3.3.7",
    "vue3-simple-icons": "^16.10.0",
    "wrangler": "^4.110.0",
    "zod": "^4.4.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ]
  }
}
